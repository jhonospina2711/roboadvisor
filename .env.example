# Base URL del sitio que se va a scrapear/indexar.
# Cambiala si quieres apuntar el asistente a otra fuente.
TARGET_URL=

# Nombre del modelo local disponible en Ollama.
# Debe coincidir con el nombre que aparece al ejecutar: ollama list
LOCAL_MODEL=

# Numero maximo de paginas que se indexan en una corrida.
# Un valor mas alto puede mejorar cobertura, pero tarda mas.
QA_MAX_PAGES=

# Cantidad de documentos/contextos recuperados para responder cada pregunta.
# Sube este valor si las respuestas necesitan mas contexto.
QA_TOP_K=

# Creatividad del modelo al responder.
# 0 = respuestas mas deterministas; valores mayores = mas variacion.
LLM_TEMPERATURE=

