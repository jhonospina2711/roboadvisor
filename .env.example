# ── Scraping ──────────────────────────────────────────────────────────────────
# URL base del sitio a indexar.
TARGET_URL=

# ── LLM provider ──────────────────────────────────────────────────────────────
# Selecciona el backend de lenguaje: 'ollama' (local) o 'gemini' (nube).
LLM_PROVIDER=ollama

# ── Ollama (LLM_PROVIDER=ollama) ──────────────────────────────────────────────
# Nombre del modelo en Ollama. Debe coincidir con: ollama list
LOCAL_MODEL=gemma4-financiero

# ── Gemini (LLM_PROVIDER=gemini) ──────────────────────────────────────────────
# Nombre del modelo de Gemini a usar.
GEMINI_MODEL=gemini-2.0-flash
# Clave de API de Google AI Studio (obligatoria cuando LLM_PROVIDER=gemini).
GOOGLE_API_KEY=

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Numero maximo de paginas indexadas por corrida.
QA_MAX_PAGES=20
# Documentos recuperados por pregunta.
QA_TOP_K=4

# ── Modelo ────────────────────────────────────────────────────────────────────
# Temperatura del modelo (0 = determinista, >0 = mas creativo).
LLM_TEMPERATURE=0
